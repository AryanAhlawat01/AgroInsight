# =============================================
# AgroInsight Environment Variables
# =============================================
# Copy this file to .env and fill in your values
# NEVER commit .env to GitHub!

# Server (deployment-ready defaults)
PORT=5000
NODE_ENV=production
JWT_SECRET=replace_with_a_long_random_secret
ALLOW_RESET_TOKEN_RESPONSE=false

# MongoDB — Atlas (recommended for deployment)
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/agroinsight?retryWrites=true&w=majority
# Local alternative:
# MONGODB_URI=mongodb://localhost:27017/agroinsight

# CORS — Frontend URL (production)
FRONTEND_URL=https://your-backend-service.onrender.com

# CORS allow-list (comma-separated origins)
CORS_ORIGINS=https://your-backend-service.onrender.com
# Local alternative:
# CORS_ORIGINS=http://localhost:5000,http://127.0.0.1:5000,http://localhost:5500,http://127.0.0.1:5500

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# Local development quick switch:
# NODE_ENV=development
