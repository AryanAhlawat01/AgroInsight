# ─── Server ───────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ─── MongoDB ──────────────────────────────────────────────
# Local:
MONGODB_URI=mongodb://localhost:27017/agroinsight

# Atlas (production):
# MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/agroinsight?retryWrites=true&w=majority

# ─── Security ─────────────────────────────────────────────
# JWT secret used for authentication tokens
JWT_SECRET=change_this_to_a_long_random_string

# Optional: add a key for external AI services
# OPENAI_API_KEY=

# ─── Rate Limiting ────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=200
