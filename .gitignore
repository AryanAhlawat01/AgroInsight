# =============================================
# .gitignore — AgroInsight
# =============================================

# ---- Environment / Secrets (NEVER commit these) ----
.env
.env.local
.env.production
.env.*.local

# ---- Node.js ----
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ---- Build outputs ----
dist/
build/
.next/
out/

# ---- OS files ----
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# ---- IDE / Editor ----
.vscode/
.idea/
*.swp
*.swo
*.sublime-project
*.sublime-workspace

# ---- Logs ----
logs/
*.log

# ---- MongoDB local data (if running local mongod) ----
data/db/

# ---- Misc ----
.cache/
.temp/
*.tmp
